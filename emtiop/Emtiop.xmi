			<element xmi:idref="EAID_E7793D3B_7886_4ef5_81BB_0320EF6B493A" xmi:type="uml:Note" scope="public">
				<model package="EAPK_68F3A560_E3C8_422e_8A8A_D3464C8A967A" tpos="0" ea_localid="8635" ea_eleType="element"/>
				<properties documentation="IEEECigreDLL inherits from DynamicsFunctionBlock." isSpecification="false" sType="Note" nType="0" scope="public"/>
				<project author="tom" version="1.0" phase="1.0" created="2026-05-14 16:44:28" modified="2026-05-14 16:45:19" complexity="1" status="Proposed"/>
				<code gentype="&lt;none&gt;"/>
