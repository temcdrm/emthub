			<element xmi:idref="EAID_5567A377_5F25_4983_8492_59C5F34B7B45" xmi:type="uml:Note" scope="public">
				<model package="EAPK_68F3A560_E3C8_422e_8A8A_D3464C8A967A" tpos="0" ea_localid="8609" ea_eleType="element"/>
				<properties documentation="The extension (top) associates SvVoltage to ConnectivityNode instead of TopologicalNode.&#xA;For ConductingEquipment, positive SvPowerFlow is defined from the Terminal into the equipment. This sign convention cannot be reversed. SvSwitch, SvStatus, SvTapStep, and SvShuntCompensatorSections are unchanged from the core CIM. SvInjection is not used.&#xA;Some inherited associations are hidden in this diagram for clarity. The phase attribute will not be used for describing positive sequence power flow results to initialize EMT. Instead, use the phase A reference angle in three-phase systems." isSpecification="false" sType="Note" nType="0" scope="public"/>
				<project author="tom" version="1.0" phase="1.0" created="2026-01-12 13:35:36" modified="2026-05-14 15:04:37" complexity="1" status="Proposed"/>
				<code gentype="&lt;none&gt;"/>
				<style appearance="BackColor=-1;BorderColor=-1;BorderWidth=-1;FontColor=-1;VSwimLanes=1;HSwimLanes=1;BorderStyle=0;"/>
				<tags/>
				<xrefs/>
				<extendedProperties tagged="0" package_name="Emtiop"/>
			</element>
			<element xmi:idref="EAID_37686F36_5816_4b4e_957A_C860E89CFC65" xmi:type="uml:Note" scope="public">
				<model package="EAPK_68F3A560_E3C8_422e_8A8A_D3464C8A967A" tpos="0" ea_localid="8608" ea_eleType="element"/>
				<properties documentation="These classes allow dynamic remote signal connections to ConnectivityNode, TransformerEnd, and either the From or To side of ConductingEquipment. It also permits the standard WeccDynamics and the extension IEEECigreDLL to use remote signals. &lt;font color=&quot;#ff0000&quot;&gt;What is the difference between remoteBusVoltage and remoteBusVoltageAmplitude?&lt;/font&gt;" isSpecification="false" sType="Note" nType="0" scope="public"/>
				<project author="tom" version="1.0" phase="1.0" created="2026-01-12 13:35:15" modified="2026-05-14 14:39:34" complexity="1" status="Proposed"/>
				<code gentype="&lt;none&gt;"/>
				<style appearance="BackColor=-1;BorderColor=-1;BorderWidth=-1;FontColor=-1;VSwimLanes=1;HSwimLanes=1;BorderStyle=0;"/>
				<tags/>
				<xrefs/>
				<extendedProperties tagged="0" package_name="Emtiop"/>
			</element>
			<element xmi:idref="EAID_118938DF_7E6A_4cdc_AC05_F82C84BFD8C5" xmi:type="uml:Note" scope="public">
				<model package="EAPK_68F3A560_E3C8_422e_8A8A_D3464C8A967A" tpos="0" ea_localid="8611" ea_eleType="element"/>
				<properties documentation="These classes associate &quot;real-code&quot; dynamic link libraries (DLLs) to inverters and other Equipment, per Cigre TB 958. The IEEECigreDLLParameter does not need to inherit from DetailedModelDescriptor because it is already uniquely identified by the association to IEEECigreDLL in combination with its own sequenceNumber." isSpecification="false" sType="Note" nType="0" scope="public"/>
				<project author="tom" version="1.0" phase="1.0" created="2026-01-15 13:23:48" modified="2026-05-14 15:27:35" complexity="1" status="Proposed"/>
				<code gentype="&lt;none&gt;"/>
				<style appearance="BackColor=-1;BorderColor=-1;BorderWidth=-1;FontColor=-1;VSwimLanes=1;HSwimLanes=1;BorderStyle=0;"/>
				<tags/>
				<xrefs/>
				<extendedProperties tagged="0" package_name="Emtiop"/>
